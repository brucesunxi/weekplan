# ===== 小计划 - 环境变量说明 =====
# 在 Vercel 部署时，在项目设置中配置以下变量

# NextAuth 加密密钥（必填）
# 运行 `openssl rand -base64 32` 生成
AUTH_SECRET=your-secret-key-here

# 部署 URL（Vercel 会自动设置）
AUTH_URL=https://your-app.vercel.app

# ===== Vercel KV =====
# 在 Vercel 控制台创建 KV 数据库后获取
# 选择 "Storage" → "Create Database" → "KV"
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ===== DeepSeek API =====
# 在 https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=
